---
import sandoval1 from '../img/sandoval1.png';
import sandoval2 from '../img/sandoval2.png';
---

<section
  class="section-view flex flex-col justify-center px-6 py-4 bg-surface/30 border-y border-white/5"
  id="proyectos"
>
  <div class="max-w-7xl mx-auto w-full">
    <h2 class="text-3xl font-bold mb-8 flex items-center gap-4">
      <span class="text-neon-green font-mono">04.</span> Proyectos Destacados
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Project Card 1: Sandoval S.A. -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-zinc-900"
        data-purpose="project-card"
      >
        <div
          class="aspect-video w-full bg-zinc-800 relative overflow-hidden"
        >
          <img src={sandoval1.src} alt="Dashboard Sandoval S.A." class="absolute inset-0 w-full h-full object-cover" />
          <img src={sandoval2.src} alt="Tickets Sandoval S.A." class="absolute inset-0 w-full h-full object-cover animate-fade-top" />
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-white mb-2">Sistema de Gestión - Sandoval S.A.</h3>
          <p class="text-zinc-400 mb-6">
            Plataforma interna para la gestión y seguimiento de tickets, control de clientes y reportes de la serviteca automotriz.
          </p>
          <div class="flex flex-wrap gap-2 mt-4">
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">AdonisJS</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">React</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">Inertia</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">TypeScript</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">TailwindCSS</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">Shadcn UI</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">PostgreSQL</span>
            <span class="px-2 py-1 bg-white/5 text-[10px] uppercase text-zinc-300 font-mono">Docker</span>
          </div>
          <div class="flex gap-4 mt-6">
            <span class="text-neon-green font-bold">Github</span>
            <span class="text-white">Repositorio Privado</span>
          </div>
        </div>
      </div>
      <!-- Project Card 2: ZenFlow App -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-zinc-900"
        data-purpose="project-card"
      >
        <div
          class="aspect-video w-full bg-zinc-800 flex items-center justify-center"
        >
          <span class="text-neon-green/20 font-bold text-4xl">ZENFLOW APP</span>
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-white mb-2 flex flex-wrap items-center gap-3">
            ZenFlow App
            <span class="text-[10px] uppercase tracking-wider px-2 py-1 bg-white/5 text-zinc-300 rounded-full border border-white/10">Trabajo en proceso</span>
          </h3>
          <p class="text-zinc-400 mb-6">
            Aplicación móvil de productividad con enfoque minimalista y
            sincronización offline.
          </p>
          <div class="flex gap-4">
            <a class="text-neon-green hover:underline font-bold" href="#"
              >App Store</a
            >
            <a
              class="text-white hover:text-neon-green transition-colors"
              href="#">Case Study</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-top {
    /* 10 seconds total: 4s visible, 1s fade out, 4s invisible, 1s fade in */
    animation: fadeTop 10s infinite;
  }
  @keyframes fadeTop {
    0%, 40% { opacity: 0; }
    50%, 90% { opacity: 1; }
    100% { opacity: 0; }
  }
</style>
