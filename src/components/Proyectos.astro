---

---

<section
  class="section-view flex flex-col justify-center px-6 py-4 bg-surface/30 border-y border-white/5"
  id="proyectos"
>
  <div class="max-w-7xl mx-auto w-full">
    <h2 class="text-3xl font-bold mb-8 flex items-center gap-4">
      <span class="text-neon-green font-mono">04.</span> Proyectos Destacados
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Project Card 1: Analytics Pro -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-zinc-900"
        data-purpose="project-card"
      >
        <div
          class="aspect-video w-full bg-zinc-800 flex items-center justify-center"
        >
          <span class="text-neon-green/20 font-bold text-4xl"
            >ANALYTICS PRO</span
          >
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-white mb-2">Analytics Pro</h3>
          <p class="text-zinc-400 mb-6">
            Plataforma de visualización de datos masivos en tiempo real
            utilizando WebGL y WebSockets.
          </p>
          <div class="flex gap-4">
            <a class="text-neon-green hover:underline font-bold" href="#"
              >Ver Demo</a
            >
            <a
              class="text-white hover:text-neon-green transition-colors"
              href="#">Github</a
            >
          </div>
        </div>
      </div>
      <!-- Project Card 2: ZenFlow App -->
      <div
        class="group relative overflow-hidden rounded-2xl bg-zinc-900"
        data-purpose="project-card"
      >
        <div
          class="aspect-video w-full bg-zinc-800 flex items-center justify-center"
        >
          <span class="text-neon-green/20 font-bold text-4xl">ZENFLOW APP</span>
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold text-white mb-2">ZenFlow App</h3>
          <p class="text-zinc-400 mb-6">
            Aplicación móvil de productividad con enfoque minimalista y
            sincronización offline.
          </p>
          <div class="flex gap-4">
            <a class="text-neon-green hover:underline font-bold" href="#"
              >App Store</a
            >
            <a
              class="text-white hover:text-neon-green transition-colors"
              href="#">Case Study</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
