---

<section
  class="section-view flex flex-col justify-center px-6 py-4"
  id="trayectoria"
>
  <div class="max-w-7xl mx-auto w-full">
    <h2 class="text-3xl font-bold mb-8 flex items-center gap-4">
      <span class="text-neon-green font-mono">03.</span> Trayectoria Profesional
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Timeline Card 1 -->
      <div
        class="relative p-8 bg-zinc-900/50 border border-white/5 rounded-xl hover:border-neon-green/50 transition-all group"
      >
        <div class="text-neon-green mb-4 font-mono text-sm tracking-widest">
          JUN 2025 — DIC 2025
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">
          Administrador de Pañol TI
        </h3>
        <p class="text-zinc-400 leading-relaxed mb-4">
          Gestión de inventario tecnológico, mantenimiento básico de hardware y
          soporte operativo a docentes y estudiantes en laboratorios e
          infraestructura escolar.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Soporte Operativo</span
          >
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Hardware</span
          >
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Gestión TI</span
          >
        </div>
      </div>
      <!-- Timeline Card 2 -->
      <div
        class="relative p-8 bg-zinc-900/50 border border-white/5 rounded-xl hover:border-neon-green/50 transition-all group"
      >
        <div class="text-neon-green mb-4 font-mono text-sm tracking-widest">
          NOV 2024 — JUN 2025
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">
          Profesor de Informática
        </h3>
        <p class="text-zinc-400 leading-relaxed mb-4">
          Docencia y liderazgo de talleres en programación y redes (INSUCO
          Chillán). Ejecución de la reestructuración integral de la red,
          instalando cableado estructurado y equipos Ubiquiti.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Docencia</span
          >
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Programación y Buenas Prácticas</span
          >
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Redes / Ubiquiti</span
          >
          <span class="px-2 py-1 bg-white/5 text-[10px] uppercase"
            >Liderazgo</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
