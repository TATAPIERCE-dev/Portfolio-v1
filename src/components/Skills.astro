---

---

<section
  class="section-view flex flex-col justify-center px-6 py-4 bg-surface/30 border-y border-white/5"
  id="skills"
>
  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl font-bold mb-8 flex items-center gap-4">
        <span class="text-neon-green font-mono">01.</span> Skills
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div
          class="p-4 border border-white/10 rounded-lg hover:border-neon-green transition-all bg-white/5 flex flex-col justify-between group"
        >
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Frontend</h3>
            <p class="text-sm text-zinc-400">React, Next.js, Tailwind</p>
          </div>
          <div class="flex gap-3 mt-4 items-center">
            <img
              src="https://cdn.simpleicons.org/react/39FF14"
              alt="React"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="React"
            />
            <img
              src="https://cdn.simpleicons.org/nextdotjs/39FF14"
              alt="Next.js"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Next.js"
            />
            <img
              src="https://cdn.simpleicons.org/tailwindcss/39FF14"
              alt="Tailwind CSS"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Tailwind CSS"
            />
          </div>
        </div>
        <div
          class="p-4 border border-white/10 rounded-lg hover:border-neon-green transition-all bg-white/5 flex flex-col justify-between group"
        >
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Backend</h3>
            <p class="text-sm text-zinc-400">Node, Go, Python</p>
          </div>
          <div class="flex gap-3 mt-4 items-center">
            <img
              src="https://cdn.simpleicons.org/nodedotjs/39FF14"
              alt="Node.js"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Node.js"
            />
            <img
              src="https://cdn.simpleicons.org/go/39FF14"
              alt="Go"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Go"
            />
            <img
              src="https://cdn.simpleicons.org/python/39FF14"
              alt="Python"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Python"
            />
          </div>
        </div>
        <div
          class="p-4 border border-white/10 rounded-lg hover:border-neon-green transition-all bg-white/5 flex flex-col justify-between group"
        >
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Host</h3>
            <p class="text-sm text-zinc-400">AWS, Vercel, Netlify</p>
          </div>
          <div class="flex gap-3 mt-4 items-center">
            <svg class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity" title="AWS" xml:space="preserve" viewBox="0 0 304 182"><path fill="#ffffff" d="m86 66 2 9c0 3 1 5 3 8v2l-1 3-7 4-2 1-3-1-4-5-3-6c-8 9-18 14-29 14-9 0-16-3-20-8-5-4-8-11-8-19s3-15 9-20c6-6 14-8 25-8a79 79 0 0 1 22 3v-7c0-8-2-13-5-16-3-4-8-5-16-5l-11 1a80 80 0 0 0-14 5h-2c-1 0-2-1-2-3v-5l1-3c0-1 1-2 3-2l12-5 16-2c12 0 20 3 26 8 5 6 8 14 8 25v32zM46 82l10-2c4-1 7-4 10-7l3-6 1-9v-4a84 84 0 0 0-19-2c-6 0-11 1-15 4-3 2-4 6-4 11s1 8 3 11c3 2 6 4 11 4zm80 10-4-1-2-3-23-78-1-4 2-2h10l4 1 2 4 17 66 15-66 2-4 4-1h8l4 1 2 4 16 67 17-67 2-4 4-1h9c2 0 3 1 3 2v2l-1 2-24 78-2 4-4 1h-9l-4-1-1-4-16-65-15 64-2 4-4 1h-9zm129 3a66 66 0 0 1-27-6l-3-3-1-2v-5c0-2 1-3 2-3h2l3 1a54 54 0 0 0 23 5c6 0 11-2 14-4 4-2 5-5 5-9l-2-7-10-5-15-5c-7-2-13-6-16-10a24 24 0 0 1 5-34l10-5a44 44 0 0 1 20-2 110 110 0 0 1 12 3l4 2 3 2 1 4v4c0 3-1 4-2 4l-4-2c-6-2-12-3-19-3-6 0-11 0-14 2s-4 5-4 9c0 3 1 5 3 7s5 4 11 6l14 4c7 3 12 6 15 10s5 9 5 14l-3 12-7 8c-3 3-7 5-11 6l-14 2z"/><path d="M274 144A220 220 0 0 1 4 124c-4-3-1-6 2-4a300 300 0 0 0 263 16c5-2 10 4 5 8z" fill="#f90"/><path d="M287 128c-4-5-28-3-38-1-4 0-4-3-1-5 19-13 50-9 53-5 4 5-1 36-18 51-3 2-6 1-5-2 5-10 13-33 9-38z" fill="#f90"/></svg>
            <img
              src="https://cdn.simpleicons.org/vercel/39FF14"
              alt="Vercel"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Vercel"
            />
            <img
              src="https://cdn.simpleicons.org/netlify/39FF14"
              alt="Netlify"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="Netlify"
            />
          </div>
        </div>

        <div
          class="p-4 border border-white/10 rounded-lg hover:border-neon-green transition-all bg-white/5 flex flex-col justify-between group"
        >
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Database</h3>
            <p class="text-sm text-zinc-400">PostgreSQL, MongoDB</p>
          </div>
          <div class="flex gap-3 mt-4 items-center">
            <img
              src="https://cdn.simpleicons.org/postgresql/39FF14"
              alt="PostgreSQL"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="PostgreSQL"
            />
            <img
              src="https://cdn.simpleicons.org/mongodb/39FF14"
              alt="MongoDB"
              class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity"
              title="MongoDB"
            />
          </div>
        </div>
      </div>
    </div>
    <div>
      <h2 class="text-3xl font-bold mb-8 flex items-center gap-4">
        <span class="text-neon-green font-mono">02.</span> Certificaciones
      </h2>
      <ul class="space-y-6">
        <li class="flex items-start gap-4 group">
          <svg class="w-6 h-6 mt-1 opacity-70 group-hover:opacity-100 transition-opacity" title="AWS" xml:space="preserve" viewBox="0 0 304 182"><path fill="#ffffff" d="m86 66 2 9c0 3 1 5 3 8v2l-1 3-7 4-2 1-3-1-4-5-3-6c-8 9-18 14-29 14-9 0-16-3-20-8-5-4-8-11-8-19s3-15 9-20c6-6 14-8 25-8a79 79 0 0 1 22 3v-7c0-8-2-13-5-16-3-4-8-5-16-5l-11 1a80 80 0 0 0-14 5h-2c-1 0-2-1-2-3v-5l1-3c0-1 1-2 3-2l12-5 16-2c12 0 20 3 26 8 5 6 8 14 8 25v32zM46 82l10-2c4-1 7-4 10-7l3-6 1-9v-4a84 84 0 0 0-19-2c-6 0-11 1-15 4-3 2-4 6-4 11s1 8 3 11c3 2 6 4 11 4zm80 10-4-1-2-3-23-78-1-4 2-2h10l4 1 2 4 17 66 15-66 2-4 4-1h8l4 1 2 4 16 67 17-67 2-4 4-1h9c2 0 3 1 3 2v2l-1 2-24 78-2 4-4 1h-9l-4-1-1-4-16-65-15 64-2 4-4 1h-9zm129 3a66 66 0 0 1-27-6l-3-3-1-2v-5c0-2 1-3 2-3h2l3 1a54 54 0 0 0 23 5c6 0 11-2 14-4 4-2 5-5 5-9l-2-7-10-5-15-5c-7-2-13-6-16-10a24 24 0 0 1 5-34l10-5a44 44 0 0 1 20-2 110 110 0 0 1 12 3l4 2 3 2 1 4v4c0 3-1 4-2 4l-4-2c-6-2-12-3-19-3-6 0-11 0-14 2s-4 5-4 9c0 3 1 5 3 7s5 4 11 6l14 4c7 3 12 6 15 10s5 9 5 14l-3 12-7 8c-3 3-7 5-11 6l-14 2z"/><path d="M274 144A220 220 0 0 1 4 124c-4-3-1-6 2-4a300 300 0 0 0 263 16c5-2 10 4 5 8z" fill="#f90"/><path d="M287 128c-4-5-28-3-38-1-4 0-4-3-1-5 19-13 50-9 53-5 4 5-1 36-18 51-3 2-6 1-5-2 5-10 13-33 9-38z" fill="#f90"/></svg>
          <div>
            <h3
              class="text-xl font-bold text-white group-hover:text-neon-green transition-colors"
            >
              AWS Academy Cloud Foundations
            </h3>
            <p class="text-sm text-zinc-500 uppercase tracking-widest mt-1">
              Amazon Web Services · 2023
            </p>
          </div>
        </li>
        <li class="flex items-start gap-4 group">
          <img
            src="https://cdn.simpleicons.org/udemy/39FF14"
            alt="Udemy"
            class="w-6 h-6 mt-1 opacity-70 group-hover:opacity-100 transition-opacity"
          />
          <div>
            <h3
              class="text-xl font-bold text-white group-hover:text-neon-green transition-colors leading-tight"
            >
              Desarrollo Web Completo con HTML5, CSS3, JS AJAX PHP y MySQL
            </h3>
            <p class="text-sm text-zinc-500 uppercase tracking-widest mt-1">
              Udemy · 2026
            </p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
