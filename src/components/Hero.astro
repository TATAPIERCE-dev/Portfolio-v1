---

---

<section
  class="section-view flex flex-col items-center justify-center relative px-6 pt-24 pb-0"
  id="hero"
>
  <div class="text-center space-y-4 max-w-4xl">
    <!-- Profile Image Container -->
    <div class="relative inline-block group" data-purpose="profile-picture">
      <div
        class="absolute -inset-1 bg-neon-green rounded-full blur opacity-40 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"
      >
      </div>
      <div
        class="relative w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-4 border-neon-green/30"
      >
        <img
          alt="Rodrigo Sandoval"
          class="w-full h-full object-cover"
          src="/profile.jpg"
        />
      </div>
    </div>
    <div class="space-y-4">
      <h1
        class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter"
      >
        Rodrigo <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-emerald-400"
          >Sandoval</span
        >
      </h1>
      <p
        class="text-xl md:text-2xl font-mono text-neon-green animate-glow tracking-widest uppercase"
      >
        Ingeniero en Informática
      </p>
      <p
        class="text-xl md:text-2xl font-mono text-neon-green animate-glow tracking-widest uppercase"
      >
        Desarrollador Web
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-4 mt-8">
      <a
        href="#proyectos"
        class="inline-block px-8 py-3 bg-neon-green text-black font-bold rounded-sm hover:bg-white transition-all transform hover:-translate-y-1"
        >VER PROYECTOS</a
      >
      <a
        href="#"
        class="inline-block px-8 py-3 border border-neon-green text-neon-green font-bold rounded-sm hover:bg-neon-green/10 transition-all"
        >REVISAR CV</a
      >
    </div>
  </div>
  <!-- Scroll Indicator -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-neon-green/50"
  >
    <svg
      class="h-8 w-8"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"></path>
    </svg>
  </div>
</section>
